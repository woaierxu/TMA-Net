# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments and packaging
.Python
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.cache/

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Logs and experiment outputs
*.log
logs/
log/
runs/
wandb/
tensorboard/
events.out.tfevents*
outputs/
output/
results/
result/
exp/
experiments/
snapshot/
snapshots/
checkpoint/
checkpoints/
save/
saves/

