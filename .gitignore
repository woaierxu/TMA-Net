*.pth
*.pt
*.ckpt
*.bin
*.onnx
*.pkl
*.pickle
*.safetensors
!Code/biomed_clip/embeddings/*.pth

# Dataset files: keep split lists and metadata, ignore bulky data arrays/images
Code/Datasets/**/*.h5
Code/Datasets/**/*.hdf5
Code/Datasets/**/*.nii
Code/Datasets/**/*.nii.gz
Code/Datasets/**/*.mha
Code/Datasets/**/*.mhd
Code/Datasets/**/*.raw
Code/Datasets/**/*.npy
Code/Datasets/**/*.npz
Code/Datasets/**/*.mat
Code/Datasets/**/*.dcm
Code/Datasets/**/*.zip
Code/Datasets/**/*.tar
Code/Datasets/**/*.tar.gz
Code/Datasets/**/*.rar
Code/Datasets/**/*.7z

